# ---- Client (NEXT_PUBLIC, inlined at build) ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Also enforced server-side: order creation refuses unless this is 'true'.
NEXT_PUBLIC_PAYMENTS_ENABLED=false
# Leave unset for same-origin /api/v1. Set only if pointing at a separate API host.
# NEXT_PUBLIC_API_URL=

# ---- Server core ----
APP_BASE_URL=http://localhost:3000
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
MODEL_TIER=cost

# Required for preview generation.
OPENAI_API_KEY=
GEMINI_API_KEY=

# Model names are configurable because providers rename image/text models.
OPENAI_TEXT_MODEL=gpt-4o
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL_COST=gemini-2.5-flash-image
GEMINI_IMAGE_MODEL_QUALITY=gemini-3-pro-image
STORY_TEMPERATURE=0.7

# Alpha knobs.
BETA_ACCESS_CODE=
PREVIEW_DAILY_CAP=10
PREVIEW_RETENTION_DAYS=30
MAX_IMAGE_ATTEMPTS=2

# Inngest: leave blank locally when using inngest dev; set in hosted alpha.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Optional until payments/email/admin are tested.
ADMIN_API_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RESEND_API_KEY=
EMAIL_FROM=Plumtale <onboarding@resend.dev>
# Ops alerts (amount mismatches, cost overruns) are emailed here when set.
ALERT_EMAIL=

# Optional observability.
SENTRY_DSN=

# Required only for migrations.
# DATABASE_URL=
