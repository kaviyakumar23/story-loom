# ---- Client (NEXT_PUBLIC, inlined at build) ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Also enforced server-side: order creation refuses unless this is 'true'.
NEXT_PUBLIC_PAYMENTS_ENABLED=false
# Leave unset for same-origin /api/v1. Set only if pointing at a separate API host.
# NEXT_PUBLIC_API_URL=

# ---- Server core ----
APP_BASE_URL=http://localhost:3000
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Default tier for both text and images.
MODEL_TIER=cost
# Optional per-capability overrides. Images are ~90% of cost-per-book (~16 per
# book); a quality story is cents. Launch setting: quality text + cost images.
TEXT_MODEL_TIER=
IMAGE_MODEL_TIER=

# Required for preview generation.
OPENAI_API_KEY=
# Gemini via AI Studio (Developer API). Needed only for GEMINI_BACKEND=studio.
GEMINI_API_KEY=

# ---- Gemini backend ----
# `studio` = AI Studio API key (GEMINI_API_KEY above).
# `vertex` = Vertex AI on Google Cloud — use this on a plain gcloud project /
# free-credits account, which has no AI Studio key.
# Leave blank to auto-pick: vertex when any GOOGLE_* var below is set.
GEMINI_BACKEND=
# Google Cloud project id (must have the Vertex AI API enabled). Optional if your
# ADC login already has a quota project — that project is used automatically.
GOOGLE_CLOUD_PROJECT=
# Region that serves the Gemini models (e.g. us-central1, or `global`).
GOOGLE_CLOUD_LOCATION=us-central1
#
# Vertex credentials — pick ONE:
#   Local dev: `gcloud auth application-default login` (nothing to set here; the
#     ADC file at ~/.config/gcloud/application_default_credentials.json is read).
#   Host with a service-account key: base64 the JSON ("Vertex AI User" role):
#     base64 -i service-account.json | tr -d '\n'
GOOGLE_SERVICE_ACCOUNT_KEY=
#
# Keyless prod via Workload Identity Federation (use when org policy blocks SA
# keys — e.g. Vercel). The runtime OIDC token is traded for a Vertex token; no
# secret is stored. Set the STS audience + the SA to impersonate:
#   GOOGLE_WORKLOAD_IDENTITY_AUDIENCE=//iam.googleapis.com/projects/<NUM>/locations/global/workloadIdentityPools/<POOL>/providers/<PROVIDER>
#   GOOGLE_IMPERSONATE_SERVICE_ACCOUNT=<sa>@<project>.iam.gserviceaccount.com
# On Vercel, enable OIDC federation so VERCEL_OIDC_TOKEN is injected at runtime.
GOOGLE_WORKLOAD_IDENTITY_AUDIENCE=
GOOGLE_IMPERSONATE_SERVICE_ACCOUNT=
GOOGLE_SUBJECT_TOKEN_ENV=VERCEL_OIDC_TOKEN

# Model names are configurable because providers rename image/text models.
OPENAI_TEXT_MODEL=gpt-4o
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL_COST=gemini-2.5-flash-image
GEMINI_IMAGE_MODEL_QUALITY=gemini-3-pro-image
STORY_TEMPERATURE=0.7

# Alpha knobs.
BETA_ACCESS_CODE=
PREVIEW_DAILY_CAP=10
PREVIEW_RETENTION_DAYS=30
MAX_IMAGE_ATTEMPTS=2

# Inngest: leave blank locally when using inngest dev; set in hosted alpha.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Optional until payments/email/admin are tested.
ADMIN_API_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RESEND_API_KEY=
EMAIL_FROM=MoonBell <onboarding@resend.dev>
# Ops alerts (amount mismatches, cost overruns) are emailed here when set.
ALERT_EMAIL=

# Optional observability.
SENTRY_DSN=

# Required only for migrations.
# DATABASE_URL=
